# run: hyprctl clients

$terminal   = Alacritty|Kitty
$browser    = firefox|librewolf|Tor Browser
$message    = discord|org.gajim.Gajim|Element|Session|Telegram|info.mumble.Mumble
$streaming  = Spotify|FreeTube|streamlink-twitch-gui|mpv
$gaming     = dofus.exe
$music      = org.musescore.MuseScore
$libvirt    = virt-viewer

windowrulev2 = workspace 1,     class:^($terminal)
windowrulev2 = workspace 2,     class:^($browser)
windowrulev2 = workspace 3,     class:^($message)
windowrulev2 = workspace 4,     class:^($streaming), title:^($streaming)
windowrulev2 = workspace 5,     class:^($gaming)
windowrulev2 = workspace 6,     class:^($music)
windowrulev2 = workspace 7,     class:^($libvirt)

windowrulev2 = float,           class:^($terminal|$browser|$streaming|$message|$gaming|$libvirt)$, title:^($streaming)
windowrulev2 = move 0 0,        class:^($terminal|$browser|$streaming|$message|$gaming|$libvirt)$, title:^($streaming)
windowrulev2 = size 100% 1044,  class:^($terminal|$browser|$streaming|$message|$gaming|$libvirt)$, title:^($streaming)
windowrulev2 = noborder,        class:^($terminal|$browser|$streaming|$message|$gaming|$libvirt)$, title:^($streaming)
windowrulev2 = rounding 0,      class:^($terminal|$browser|$streaming|$message|$gaming|$libvirt)$, title:^($streaming)
windowrulev2 = noshadow,        class:^($terminal|$browser|$streaming|$message|$gaming|$libvirt)$, title:^($streaming)

# custom
windowrulev2 = float,           class:^(udiskie)$
windowrulev2 = move 40% 40%,    class:^(udiskie)$
