# run: hyprctl clients

$terminal   = Alacritty|Kitty
$browser    = zen-beta|firefox|librewolf      # zen-twilight
$message    = discord|org.gajim.Gajim|Element|Session|org.telegram.dekstop|info.mumble.Mumble
$streaming  = spotify|FreeTube|streamlink-twitch-gui|mpv
$gaming     = dofus.exe
$music      = org.musescore.MuseScore
$libvirt    = virt-viewer

windowrulev2 = float, class:.*
windowrulev2 = move 6 52, class:.*
#windowrulev2 = size 99.4% 95%, class:.*
windowrulev2 = size 1908 1142, class:.*     # 1920-, 1200-

windowrulev2 = noborder,        class:^($browser)$
windowrulev2 = workspace 1,     class:^($terminal)
windowrulev2 = workspace 2,     class:^($browser)
windowrulev2 = workspace 3,     class:^($message)
windowrulev2 = workspace 4,     class:^($streaming), title:^($streaming)
# windowrulev2 = workspace 5,     class:^($gaming)
# windowrulev2 = workspace 6,     class:^($music)
# windowrulev2 = workspace 7,     class:^($libvirt)

windowrulev2 = float,           class:^(udiskie)$
windowrulev2 = move 40% 40%,    class:^(udiskie)$
