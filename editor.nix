# https://editorconfig.org/
## not imported
{
  editorconfig = {
    enable = true;
    settings = {
      "*" = {
        charset        = "utf-8";
        end_of_line    = "lf";
        max_line_width = 78;
        indent_style   = "space";
        indent_size    = 4;
        insert_final_newline     = true;
        trim_trailing_whitespace = true;
      };
    };
  };
}
